# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Database
POSTGRES_USER=legal_th
POSTGRES_PASSWORD=legal_th_pass
POSTGRES_DB=legal_th

# Auth
API_KEY_SALT=change-this-to-random-string

# Rate Limiting
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# Logging
LOG_LEVEL=info

# Cloudflare Tunnel (ใส่เฉพาะเมื่อใช้ tunnel profile)
# สร้าง Tunnel บน Cloudflare Dashboard → copy token มาวาง
CF_TUNNEL_TOKEN=
